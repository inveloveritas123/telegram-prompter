# Telegram API — Test-Framework Konfiguration
TELEGRAM_API_ID=1234567890
TELEGRAM_API_HASH=abcdef0123456789abcdef0123456789
TELEGRAM_TEST_SESSION=test_session_placeholder
TELEGRAM_ALLOWED_TEST_BOTS=@testbot1,@testbot2
HTTP_FORBIDDEN_HOSTS=prod.example.com,real-api.example.com

# n8n Integration
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=n8n_api_key_placeholder

# Telegram Benachrichtigungen
NOTIFY_BOT_TOKEN=telegram_notify_bot_token_placeholder
NOTIFY_CHAT_ID=123456789

# Orchestrator — Pipeline-Engine
ORCHESTRATOR_ENGINE=mock
# Alternative: ORCHESTRATOR_ENGINE=claude (erfordert ~/.claude Auth)

# GitHub Integration (optional — ohne Token wird PR simuliert)
GITHUB_TOKEN=

# Admin-API Sicherheit
ADMIN_SECRET_KEY=admin_secret_key_placeholder

# prompter-mcp Server URL
PROMPTER_MCP_URL=http://prompter-mcp:8080/mcp
