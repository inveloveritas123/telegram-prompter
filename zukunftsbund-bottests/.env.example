# --- Telegram-Treiber (SEPARATER Test-Account, nie privat/produktiv) ---
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# StringSession des Test-Accounts (einmalig erzeugen, sicher halten):
TELEGRAM_TEST_SESSION=

# Sicherheits-Riegel: nur diese Bots dürfen getestet werden (Komma-getrennt).
# Leer = kein Filter (nur im Dry-Run sinnvoll).
TELEGRAM_ALLOWED_TEST_BOTS=@zkb_kontakt_bot_test

# Sammelfenster für Bot-Antworten (Sekunden)
TG_COLLECT_WINDOW_S=6

# --- n8n (zweite Prüfebene) ---
N8N_BASE_URL=https://n8n-staging.example
N8N_API_KEY=

# --- HTTP-Adapter Sicherheits-Riegel: gesperrte (Produktions-)Hosts ---
HTTP_FORBIDDEN_HOSTS=app.content-autopilot.example,api.produktion.example

# --- Secrets für Szenarien (per {{ env.NAME }} referenziert) ---
TEST_PASSWORT=

# --- Optional: Telegram-Benachrichtigung nach dem Lauf ---
NOTIFY_BOT_TOKEN=
NOTIFY_CHAT_ID=
